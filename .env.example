# ==========================================================================
# InstaAqui Magnético — Variáveis de ambiente (MODELO)
# Copie este arquivo para ".env" e preencha com suas chaves reais.
# NUNCA suba o .env para o Git.
# ==========================================================================

# --- Banco de dados (Postgres do Vercel / Neon) --------------------------
# No Vercel: Storage -> sua database -> aba ".env.local" mostra estas duas.
# DATABASE_URL          = conexão "pooled" (uso normal do app)
# DATABASE_URL_UNPOOLED = conexão direta (usada nas migrações)
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://usuario:senha@host:5432/banco?sslmode=require"

# --- Autenticação (Auth.js / NextAuth) -----------------------------------
# Gere um segredo aleatório com:  npx auth secret
AUTH_SECRET="troque-por-um-segredo-aleatorio-longo"

# --- Coleta de Instagram (Apify) — usado a partir da Fase 1 --------------
APIFY_TOKEN=""
# URL pública do app (para o webhook da Apify). Em produção no Vercel é
# detectada automaticamente; só preencha se usar domínio próprio.
APP_URL=""

# --- Inteligência Artificial (Groq — grátis, sem cartão) — Fase 2 --------
# Pegue em https://console.groq.com/keys  (chave começa com "gsk_")
GROQ_API_KEY=""

# --- Agendador (Inngest) — Fase 3 ----------------------------------------
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
