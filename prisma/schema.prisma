// InstaAqui Magnético — Schema do banco de dados
// Fase 0 — Fundação: multi-tenant + autenticação (Auth.js)
// Documentação: ../docs/FASE-0-FUNDACAO.txt

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")          // conexão "pooled" (uso normal do app)
  directUrl = env("DATABASE_URL_UNPOOLED") // conexão direta (migrações) — Vercel/Neon
}

// ----------------------------------------------------------------------------
// Multi-tenant — cada cliente tem sua Organization; quase tudo pertence a ela.
// ----------------------------------------------------------------------------

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // login por e-mail/senha (null se for só OAuth)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  memberships   Membership[]
  accounts      Account[]
  sessions      Session[]
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  memberships  Membership[]
  subscription Subscription?
  projects     Project[]
}

model Membership {
  id             String       @id @default(cuid())
  role           Role         @default(OWNER)
  createdAt      DateTime     @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Subscription {
  id                   String             @id @default(cuid())
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organizationId       String             @unique
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------------
// Fase 1 — Coleta: projetos de análise, concorrentes, conteúdos e jobs.
// ----------------------------------------------------------------------------

enum ContentType {
  REELS
  CAROUSEL
  IMAGE
  VIDEO
  STORY
  UNKNOWN
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Project {
  id             String       @id @default(cuid())
  name           String
  niche          String? // nicho
  handle         String? // perfil próprio (@)
  objective      String? // objetivo
  language       String       @default("pt-BR")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  competitors    Competitor[]
  jobs           CollectionJob[]

  @@index([organizationId])
}

model Competitor {
  id             String    @id @default(cuid())
  handle         String // @ do concorrente (sem o @)
  displayName    String?
  bio            String?
  cta            String?
  link           String?
  positioning    String? // posicionamento
  promise        String? // promessa principal
  followers      Int?
  following      Int?
  postsCount     Int?
  profilePicUrl  String?
  lastCollectedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  contents       Content[]

  @@unique([projectId, handle])
  @@index([projectId])
}

model Content {
  id            String      @id @default(cuid())
  externalId    String // id/shortcode do post no Instagram
  type          ContentType @default(UNKNOWN)
  caption       String?
  url           String?
  mediaUrl      String?
  thumbnailUrl  String?
  likes         Int?
  comments      Int?
  views         Int?
  postedAt      DateTime?
  createdAt     DateTime    @default(now())

  competitorId  String
  competitor    Competitor  @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, externalId])
  @@index([competitorId])
}

model CollectionJob {
  id             String    @id @default(cuid())
  status         JobStatus @default(PENDING)
  apifyRunId     String?
  webhookToken   String? // segredo para validar o webhook da Apify
  itemsCollected Int       @default(0)
  error          String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  competitorId   String?

  @@index([projectId])
  @@index([apifyRunId])
}

// ----------------------------------------------------------------------------
// Auth.js (NextAuth) — necessárias para o adapter / OAuth futuro.
// ----------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
